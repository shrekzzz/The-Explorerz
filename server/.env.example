# ──────────────────────────────────────────
# The-Explorerz Server Environment Variables
# Copy this file to .env and fill in values
# ──────────────────────────────────────────

NODE_ENV=development
PORT=3001

# ─── Database ────────────────────────────
DATABASE_URL=postgresql://postgres:password@localhost:5432/explorerz_db

# ─── Redis ───────────────────────────────
# Local Redis (for development)
# REDIS_URL=redis://localhost:6379

# Upstash Redis (recommended for production)
# Get your URL from: https://console.upstash.com/
# Format: rediss://default:PASSWORD@ENDPOINT:PORT
REDIS_URL=rediss://default:your-password@your-endpoint.upstash.io:6379

# ─── JWT Secrets ─────────────────────────
JWT_ACCESS_SECRET=your-access-secret-min-32-chars-long-replace-me
JWT_REFRESH_SECRET=your-refresh-secret-min-32-chars-long-replace-me
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# ─── Cloudinary ──────────────────────────
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# ─── Email (SendGrid / SMTP) ────────────
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASS=your-sendgrid-api-key
EMAIL_FROM=noreply@deshyatra.com

# ─── CORS ────────────────────────────────
CORS_ORIGINS=http://localhost:5173

# ─── Rate Limiting ──────────────────────
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# ─── Logging ─────────────────────────────
LOG_LEVEL=info
